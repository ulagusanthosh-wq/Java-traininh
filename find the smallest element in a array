import java.util.*;
public class array{
    public static void main(String[]args){
        Scanner sc=new Scanner(System.in);
        int N=sc.nextInt();
        int[]arr=new int[60];
        for(int i=0;i<N;i++){
            arr[i]=sc.nextInt();
        }
        int smallest=arr[0];
        for(int i=1;i<N;i++)
        {
            if(smallest>arr[i]){
                smallest=arr[i];
            }
        }
        
     System.out.println(smallest);
    }
}
