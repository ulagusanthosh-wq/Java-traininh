import java.io.*;
import java.util.*;

public class Solution {

    public static void main(String[] args) {
        Scanner Sc=new Scanner(System.in);
        int A,B,C;
        A=Sc.nextInt();
        B=Sc.nextInt();
        C=Sc.nextInt();
        if(A>B&&A>C)
        {
            System.out.println(A);
        }
        else if(B>A&&B>C)
        {
            System.out.println(B);
        }
        else
        {
            System.out.println(C);
        }
    }
}
