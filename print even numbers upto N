import java.io.*;
import java.util.*;
public class Solution {
    public static void main(String[] args) {
        Scanner s=new Scanner(System.in);
        int N=s.nextInt();
        for (int i = 1; i <= N; i++) 
        {
            if (i % 2 == 0)
            {
                System.out.print(i + " ");
            }
        }
        System.out.println();
    }
}
